# CherryAgent — Production Environment Variables
# Copy to .env and fill in values: cp .env.production.example .env

# App
NODE_ENV=production
PORT=3000
LOG_LEVEL=info
USER_TIMEZONE=America/Toronto

# Database (shared PostgreSQL on infra-net)
DATABASE_URL=postgresql://cherryagent:<password>@infra-db:5432/cherry_agent

# AI
GEMINI_API_KEY=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Fitbit
FITBIT_CLIENT_ID=
FITBIT_CLIENT_SECRET=
FITBIT_REDIRECT_URI=https://cherryagent.samantafluture.com/api/fitbit/callback
